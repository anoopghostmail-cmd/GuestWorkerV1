# MongoDB Connection
MONGO_URL=mongodb://localhost:27017/guestworker
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname

# Database Name
DB_NAME=guestworker

# JWT Secret Key (generate a strong random string for production)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Cookie Security Settings
# Set to "true" in production (HTTPS required)
COOKIE_SECURE=false
# Options: "lax", "strict", "none"
COOKIE_SAMESITE=lax

# CORS Allowed Origins (comma-separated)
# Development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
# Production (uncomment and use)
# ALLOWED_ORIGINS=https://guestworker.app,https://app.guestworker.app,https://guestworker.in

# Admin Activation Key
ADMIN_ACTIVATION_KEY=GW-ADMIN-2025-SECURE-KEY

# Razorpay LIVE — env only. rzp_live_* from Dashboard > Live > API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Dashboard > Webhooks.
RAZORPAY_WEBHOOK_SECRET=

# Server Port (default: 8000)
PORT=8000
